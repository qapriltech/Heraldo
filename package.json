{
  "name": "heraldo",
  "version": "1.0.0",
  "private": true,
  "description": "HÉRALDO — Plateforme de diffusion et d'activation médiatique",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "db:generate": "npm run generate --workspace=packages/database",
    "db:push": "npm run push --workspace=packages/database",
    "db:migrate": "npm run migrate --workspace=packages/database",
    "db:studio": "npm run studio --workspace=packages/database"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
