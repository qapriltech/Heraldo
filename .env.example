# Base de données PostgreSQL 16
DATABASE_URL="postgresql://heraldo:heraldo_dev_2026@localhost:5432/heraldo_dev"

# Redis 7
REDIS_URL="redis://localhost:6379"

# JWT — Authentification
JWT_SECRET="CHANGE_ME_openssl_rand_hex_32"
REFRESH_SECRET="CHANGE_ME_openssl_rand_hex_32"
JWT_ACCESS_TTL=900        # 15 minutes
JWT_REFRESH_TTL=604800    # 7 jours

# Chiffrement AES-256 données sensibles (téléphones, Mobile Money)
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_32"

# Mobile Money — Webhooks HMAC-SHA256
WAVE_WEBHOOK_SECRET=""
WAVE_MERCHANT_ID=""
ORANGE_WEBHOOK_SECRET=""
ORANGE_MERCHANT_ID=""
MTN_WEBHOOK_SECRET=""
MTN_MERCHANT_ID=""
MOOV_WEBHOOK_SECRET=""

# CinetPay — Agrégateur fallback
